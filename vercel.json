{
    "version": 2,
    "name": "stoliy",
    "buildCommand": "",
    "outputDirectory": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "routes": [
        {
            "src": "/store/(?<slug>[^/]+)",
            "dest": "/store.html?slug=$slug"
        },
        {
            "src": "/product/(?<slug>[^/]+)",
            "dest": "/products.html?slug=$slug"
        },
        {
            "src": "/category/(?<slug>[^/]+)",
            "dest": "/search.html?category=$slug"
        },
        {
            "src": "/event/(?<slug>[^/]+)",
            "dest": "/event-detail.html?slug=$slug"
        },
        {
            "src": "/profile/(?<username>[^/]+)",
            "dest": "/profile.html?username=$username"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ],
    "rewrites": [
        {
            "source": "/store/:slug",
            "destination": "/store.html?slug=:slug"
        },
        {
            "source": "/product/:slug",
            "destination": "/products.html?slug=:slug"
        },
        {
            "source": "/category/:slug",
            "destination": "/search.html?category=:slug"
        },
        {
            "source": "/event/:slug",
            "destination": "/event-detail.html?slug=:slug"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        },
        {
            "source": "/app-icon.png",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2))",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000"
                }
            ]
        }
    ]
}
